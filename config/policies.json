{
  "schema_version": "3.0",
  "tenant_id": "demo_university",

  "institution_rules": {
    "always_mask": ["ssn"],
    "pii_fields": ["ssn", "phone", "email"],
    "financial_fields": ["annual_salary", "amount_due", "amount_paid", "balance"],

    "access_rules": [
      {
        "rule_id": "AR-001",
        "description": "Full-Access clearance can access all sensitivity levels",
        "clearance": "Full-Access",
        "allowed_sensitivity": ["FERPA", "FERPA-Financial", "Institutional", "Institutional-Financial"],
        "scope": "all"
      },
      {
        "rule_id": "AR-002",
        "description": "Department-Scoped clearance can access Institutional and FERPA-academic data",
        "clearance": "Department-Scoped",
        "allowed_sensitivity": ["FERPA", "Institutional", "Institutional-Financial"],
        "scope": "role_filtered",
        "exceptions": {
          "FERPA-Financial": "own_only",
          "FERPA": "deny_standing"
        }
      },
      {
        "rule_id": "AR-003",
        "description": "Self-Scoped clearance can access Institutional data and own FERPA records only",
        "clearance": "Self-Scoped",
        "allowed_sensitivity": ["Institutional"],
        "scope": "own_only",
        "exceptions": {
          "FERPA": "own_only",
          "FERPA-Financial": "own_only",
          "Institutional-Financial": "deny"
        }
      },
      {
        "rule_id": "AR-004",
        "description": "Course-Scoped clearance can access Institutional and FERPA-academic data for assigned courses",
        "clearance": "Course-Scoped",
        "allowed_sensitivity": ["FERPA", "Institutional"],
        "scope": "course_filtered",
        "exceptions": {
          "FERPA-Financial": "own_only",
          "Institutional-Financial": "deny"
        }
      }
    ],

    "prohibited_combinations": [
      { "clearance": "Self-Scoped", "sensitivity": "FERPA", "resource_type": "grades", "reason": "FERPA: students cannot view grade records via AI" },
      { "clearance": "Department-Scoped", "sensitivity": "FERPA", "resource_type": "academic_standing", "reason": "Teachers cannot access student academic standing" }
    ]
  },

  "resources": {
    "persons": { "origin": "StudentInformationSystem", "sensitivity": "FERPA", "ttl_seconds": 300, "description": "Directory of all persons in the system" },
    "financial_information": { "origin": "StudentInformationSystem", "sensitivity": "FERPA-Financial", "ttl_seconds": 120, "description": "Tuition, salary, and payment records" },
    "grades": { "origin": "StudentInformationSystem", "sensitivity": "FERPA", "ttl_seconds": 300, "description": "Academic grade records", "scope_key": "student_id" },
    "academic_standing": { "origin": "StudentInformationSystem", "sensitivity": "FERPA", "ttl_seconds": 300, "description": "GPA, dean's list, probation status, credits completed", "scope_key": "student_id" },
    "classes": { "origin": "StudentInformationSystem", "sensitivity": "Institutional", "ttl_seconds": 600, "description": "Course schedules, enrollment, and room assignments" },
    "departments": { "origin": "InstitutionalPlanning", "sensitivity": "Institutional-Financial", "ttl_seconds": 600, "description": "Department budgets, faculty counts, and operating data" }
  },

  "model_config": {
    "model_id": "claude-sonnet-4-20250514",
    "provider": "Anthropic",
    "compliance": "SOC2-certified",
    "risk_level": "low",
    "max_tokens": 1024
  }
}